# Copy this file to .env and fill in values. Never commit .env.
# All external services (Sentry, Google, etc.) use env vars; prefer free tiers where available.

# --- Required for backend ---
DATABASE_URL=postgresql://user:password@localhost:5432/smart_dooh
REDIS_URL=redis://localhost:6379

# --- Optional: external APIs (free tiers available) ---
# Google Places (POI near driver). Without: POIs omitted, rest works.
# GOOGLE_PLACES_API_KEY=

# OpenWeatherMap (free tier: 1000 calls/day). Without: weather null.
OPENWEATHERMAP_API_KEY=

# LLM for ad creative generation: set one. OpenAI or Gemini free tiers.
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# SerpApi Google Trends (free tier: 100 searches/mo). Without: mock trends used.
# SERPAPI_API_KEY=

# --- Optional: observability (Sentry free tier) ---
# SENTRY_DSN=              # Backend
# EXPO_PUBLIC_SENTRY_DSN=  # Mobile (source maps via EAS Build / sentry-expo)

# --- Optional: admin (set ADMIN_API_KEY to require x-admin-api-key header) ---
# ADMIN_API_KEY=

# --- Optional ---
# PORT=3000

# Testing: skip emergency in ad-selection so only business ads show (set to true for simulator testing)
# SKIP_EMERGENCY_FOR_TESTING=true

# --- Mobile app (Expo): set in apps/mobile-driver or root .env ---
# EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Admin dashboard (Next.js): backend URL for server and client ---
# NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Payments & Billing (Prompt 8) ---
# Stripe (advertisers pre-pay): obtain from https://stripe.com (free tier)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # For production webhook signature verification

# Tranzila (Israeli payment gateway): obtain terminal ID from Tranzila
# TRANZILA_TERMINAL=yourterminal
