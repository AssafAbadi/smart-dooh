{
  "expo": {
    "name": "Adrive",
    "slug": "mobile-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "adrive",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adrive.mobiledriver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Adrive needs location to show nearby ads.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Adrive uses background location to serve relevant ads while driving.",
        "NSLocationAlwaysUsageDescription": "Adrive needs location to update ads on your car-top display.",
        "NSBluetoothAlwaysUsageDescription": "Adrive uses Bluetooth to detect nearby devices for ad metrics.",
        "UIBackgroundModes": [
          "location",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "google.navigation",
          "comgooglemaps",
          "google.navigation",
          "comgooglemaps"
        ]
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.adrive.mobiledriver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "runtimeVersion": "1.0.0"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Adrive needs location to show nearby ads.",
          "locationAlwaysAndWhenInUsePermission": "Adrive uses background location to serve relevant ads while driving.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6d100b4-917b-4c69-be57-1ab64fb100aa"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/e6d100b4-917b-4c69-be57-1ab64fb100aa"
    }
  }
}
